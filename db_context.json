    "common_queries": {
      "vendor performance": "GROUP BY received_material_from with SUM quantities and costs",
      "ward analysis": "GROUP BY vendor_location with SUM quantities",
      "monthly trend": "GROUP BY TO_CHAR(date::date, 'YYYY-MM') ORDER BY month",
      "material mix": "GROUP BY material with percentage of total",
      "rejection analysis": "ROUND((SUM(rejected_quantity)/NULLIF(SUM(received_quantity),0)*100)::numeric,2) AS rejection_pct",
      "top performers": "ORDER BY total_received_kg DESC LIMIT 10",
      "cost analysis": "SUM(net_procurement_cost::numeric) for inward, SUM(net_material_sales_cost::numeric) for outward"
    },
    "sql_rules": [
      "Always cast text columns to numeric: SUM(column::numeric)",
      "Use TO_CHAR(date::date, 'YYYY-MM') for monthly grouping, never strftime",
      "Use BETWEEN for date ranges: date::date BETWEEN 'YYYY-MM-DD' AND 'YYYY-MM-DD'",
      "Use NULLIF to prevent division by zero: NULLIF(denominator, 0)",
      "Use ROUND((expr)::numeric, 2) for percentages",
      "Facility names are case-sensitive: Hebbagodi, MRF, Muguluru, Jigani, GPR, Anekal, Marsur, Mayasandra, Bommasandra, Attibele",
      "inward table: received_material_from=vendor, vendor_location=ward/area",
      "outward table: customer=buyer, destination=delivery location",
      "training table: trainer=conducted_by (normalized), topic=training topic, category=training category",
      "training_attendees table: use for role-based and repeat attendee analysis"
    ]
  },
